    <!DOCTYPE html>
    <html>
    <head>
        <title>Timeline</title>

        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

        <link rel="stylesheet" href="/css/style.css">
    </head>

    <body class="bg-light">

    <div class="container mt-4">

        <!-- Post a message -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h4 class="mb-3">Post a message</h4>

                <input id="title" class="form-control mb-3" placeholder="Title">

                <textarea id="body" class="form-control mb-3" placeholder="Write something..."></textarea>

                <button class="btn btn-primary" onclick="createPost()">Post message</button>
            </div>
        </div>

        <h3 class="mb-3">Timeline</h3>

        <div id="posts"></div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>

    </body>
    </html>
