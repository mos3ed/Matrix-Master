<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= post.title %></title>
</head>
<body>

  <h1><%= post.title %></h1>
  <p><%= post.content %></p>

  <hr>

  <h2>command</h2>

  <% if (errors) { %>
    <ul style="color: red;">
      <% errors.forEach(err => { %>
        <li><%= err %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/post/<%= post._id %>/comment" method="POST">
    <textarea name="comment" rows="4" cols="40" placeholder=" write your comment here"></textarea>
    <br>
    <button type="submit">add comment </button>
  </form>

  <hr>

  <ul>
    <% post.comments.forEach(c => { %>
      <li>
        <p><%= c.text %></p>
        <small><%= c.createdAt.toLocaleString() %></small>
      </li>
    <% }) %>
  </ul>

  <a href="/"> back to main page </a>

</body>
</html>
